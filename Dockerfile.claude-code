# ---------------------------------------------------------------------------
# Claudeflare Code — container image
#
# Runs Claude Code CLI inside ttyd (web-based terminal). All API calls are
# routed through the AIG proxy Worker via outbound interception.
# ---------------------------------------------------------------------------

FROM node:22-bookworm-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    bash \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Install ttyd (web terminal)
RUN curl -fsSL https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.x86_64 \
    -o /usr/local/bin/ttyd \
    && chmod +x /usr/local/bin/ttyd

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code \
    && claude --version

# Create non-root user
RUN useradd -m -s /bin/bash coder

# Create workspace
RUN mkdir -p /workspace && chown coder:coder /workspace

# Claude Code settings: lock model to the AIG dynamic route
RUN mkdir -p /home/coder/.claude
COPY container_src/claude-settings.json /home/coder/.claude/settings.json
RUN chown -R coder:coder /home/coder/.claude

# Copy entrypoint
COPY container_src/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER coder
WORKDIR /workspace

EXPOSE 8080

ENTRYPOINT ["/entrypoint.sh"]
