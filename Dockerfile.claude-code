# ---------------------------------------------------------------------------
# Claudeflare Code — container image (IDE mode)
#
# Runs Claude Code CLI, an auxiliary terminal, a file server, and a preview
# proxy — all managed by the entrypoint via background processes.
#
# Ports (all proxied by the Worker):
#   8080  — ttyd: Claude Code main terminal
#   8081  — ttyd: auxiliary shell terminal
#   8082  — Node file-server API (browse /workspace)
#   8083  — Preview proxy (user's dev server, e.g. port 3000/5173/8000)
# ---------------------------------------------------------------------------

FROM node:22-bookworm-slim

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    bash \
    tmux \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install ttyd (web terminal)
RUN curl -fsSL https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.x86_64 \
    -o /usr/local/bin/ttyd \
    && chmod +x /usr/local/bin/ttyd

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code \
    && claude --version

# Create non-root user
RUN useradd -m -s /bin/bash coder

# Create workspace
RUN mkdir -p /workspace && chown coder:coder /workspace

# Claude Code settings: lock model to the AIG dynamic route
RUN mkdir -p /home/coder/.claude
COPY container_src/claude-settings.json /home/coder/.claude/settings.json
RUN chown -R coder:coder /home/coder/.claude

# Copy file server and preview proxy
COPY container_src/fileserver.js /opt/fileserver.js
COPY container_src/preview-proxy.js /opt/preview-proxy.js

# Install fake browser script — intercepts xdg-open / BROWSER calls and
# redirects them to the preview proxy so the IDE preview panel shows the
# user's dev server automatically.
COPY container_src/open-in-preview.sh /usr/local/bin/open-in-preview
RUN chmod +x /usr/local/bin/open-in-preview \
    && ln -s /usr/local/bin/open-in-preview /usr/local/bin/xdg-open

# Copy entrypoint
COPY container_src/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER coder
WORKDIR /workspace

EXPOSE 8080 8081 8082 8083

ENTRYPOINT ["/entrypoint.sh"]
