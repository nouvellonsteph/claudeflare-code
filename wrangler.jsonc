{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "claudeflare-code",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-09",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
		"traces": { "enabled": true }
	},
	"upload_source_maps": true,

	"assets": {
		"directory": "./public",
		"binding": "ASSETS",
		// Worker handles /api/*, /v1/*, /terminal/*, /health, /favicon.ico, /destroy
		// Static assets serve / (index.html) and any other static files
		"run_worker_first": ["/api/*", "/v1/*", "/terminal/*", "/health", "/favicon.ico", "/destroy"]
	},

	// All environment variables are set as secrets (wrangler secret put <NAME>)
	// so they persist across deploys and don't appear in source control.
	// See .dev.vars.example for the full list:
	//   GATEWAY_ID, CLOUDFLARE_ACCOUNT_ID, AIG_PROXY_URL,
	//   CF_ACCESS_AUD, CF_ACCESS_CERTS_URL, CF_AIG_TOKEN

	"containers": [
		{
			"class_name": "ClaudeCodeContainer",
			"image": "./Dockerfile.claude-code",
			"instance_type": "standard-1",
			"max_instances": 20
		}
	],
	// Workers AI binding — used for async task-complexity classification
	// via AI Gateway (env.AI.run with gateway.id option).
	"ai": {
		"binding": "AI"
	},
	"durable_objects": {
		"bindings": [
			{
				"class_name": "ClaudeCodeContainer",
				"name": "CLAUDE_CODE_CONTAINER"
			}
		]
	},
	"migrations": [
		{
			"new_sqlite_classes": ["ClaudeCodeContainer"],
			"tag": "v1"
		}
	]
}
