{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "claudeflare-code",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-09",
	"compatibility_flags": ["nodejs_compat"],
	"observability": { "enabled": true },
	"upload_source_maps": true,

	"vars": {
		// Your AI Gateway ID (slug from AI Gateway dashboard)
		"GATEWAY_ID": "",
		// Your Cloudflare account ID
		"CLOUDFLARE_ACCOUNT_ID": "",
		// The public URL of this worker (update after first deploy)
		"AIG_PROXY_URL": "",
		// Cloudflare Access audience tag (from Zero Trust > Access > Applications)
		"CF_ACCESS_AUD": "",
		// Cloudflare Access JWKs URL
		"CF_ACCESS_CERTS_URL": "",
		// Complexity classification toggle — set to false to disable for everyone.
		"COMPLEXITY_CLASSIFICATION_ENABLED": true,
		// Classification rollout sample rate (0 = never, 1 = always).
		"COMPLEXITY_CLASSIFICATION_SAMPLE_RATE": 1
	},

	"containers": [
		{
			"class_name": "ClaudeCodeContainer",
			"image": "./Dockerfile.claude-code",
			"instance_type": "standard-1",
			"max_instances": 20
		}
	],
	// Workers AI binding — used to run a small, fast model that classifies
	// task complexity (low/medium/high) for AI Gateway custom metadata.
	"ai": {
		"binding": "AI"
	},
	"durable_objects": {
		"bindings": [
			{
				"class_name": "ClaudeCodeContainer",
				"name": "CLAUDE_CODE_CONTAINER"
			}
		]
	},
	"migrations": [
		{
			"new_sqlite_classes": ["ClaudeCodeContainer"],
			"tag": "v1"
		}
	]
}
